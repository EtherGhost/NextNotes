# Copy this file to .env.test.local and fill in a dedicated Nextcloud test user.
# Do not use a personal account or main password. Use a Nextcloud app password.

NEXTNOTES_TEST_SERVER=https://example.com
NEXTNOTES_TEST_USERNAME=nextnotes-test
NEXTNOTES_TEST_APP_PASSWORD=replace-with-app-password

# Optional desktop debug login:
# ~/.local/bin/clickable script desktop-test
# This is ignored on Ubuntu Touch and only enabled by the desktop-test script.
NEXTNOTES_DESKTOP_TEST_AUTH=0

# Live tests are opt-in. Keep this unset or 0 unless you intentionally want
# tests to create/update/delete notes on the configured test account.
NEXTNOTES_RUN_LIVE_TESTS=1
